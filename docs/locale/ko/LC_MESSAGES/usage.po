msgstr "인스턴스가 위치한 리전, 예: ``ap-northeast-2``."

#: ../../usage.rst:21
msgid "Instance ID"
msgstr "Instance ID"

#: ../../usage.rst:22
msgid "The EC2 instance ID, e.g. ``i-xxxxxxxxxxxxxxxxx``."
msgstr "EC2 인스턴스 ID, 예: ``i-xxxxxxxxxxxxxxxxx``."

